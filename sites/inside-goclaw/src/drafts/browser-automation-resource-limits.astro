---
// Draft: browser-automation-resource-limits — raw HTML preserved
const rawHtml = `<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>GoClaw v2.17.0 — Browser Automation Resource Limits</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0b0f0c;
    --surface: #111710;
    --surface2: #192116;
    --border: #243020;
    --green: #22c55e;
    --green-dim: rgba(34,197,94,0.12);
    --green-glow: rgba(34,197,94,0.06);
    --gray: #94a3a0;
    --cream: #e8f0ec;
    --muted: #4a6358;
    --text: #b8cfc4;
    --text-dim: #3a5040;
    --red: #ef4444;
    --orange: #f97316;
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }

  .float-home { position: fixed; bottom: 24px; left: 24px; z-index: 100; width: 44px; height: 44px; border-radius: 12px; background: rgba(17,23,16,0.9); backdrop-filter: blur(12px); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; transition: all 0.25s; box-shadow: 0 4px 16px rgba(0,0,0,0.5); }
  .float-home:hover { background: var(--green); color: var(--bg); border-color: transparent; transform: translateY(-2px); }
  .float-home svg { width: 18px; height: 18px; }

  .lang-bar { position: fixed; top: 20px; right: 20px; z-index: 100; display: flex; gap: 4px; background: rgba(17,23,16,0.9); backdrop-filter: blur(12px); border: 1px solid var(--border); border-radius: 10px; padding: 4px; }
  .lang-btn { padding: 5px 12px; border-radius: 7px; font-family: var(--mono); font-size: 11px; cursor: pointer; border: none; background: transparent; color: var(--muted); transition: all 0.2s; }
  .lang-btn.active { background: var(--green); color: var(--bg); font-weight: 700; }

  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 80px 24px 60px; position: relative; overflow: hidden; background: var(--bg); }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 50% at 50% 30%, rgba(34,197,94,0.08) 0%, transparent 60%); pointer-events: none; }
  .hero-version { display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; border: 1px solid var(--border); border-radius: 100px; font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 36px; letter-spacing: 0.04em; animation: fadeUp 0.8s ease both; }
  .hero-version .dot { width: 7px; height: 7px; background: var(--green); border-radius: 50%; animation: blink 2.5s infinite; }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
  .hero h1 { font-family: var(--serif); font-size: clamp(38px, 6.5vw, 84px); font-weight: 400; line-height: 1.05; color: var(--cream); max-width: 860px; animation: fadeUp 0.9s ease 0.1s both; }
  .hero h1 em { font-style: italic; color: var(--green); }
  .hero-sub { max-width: 580px; font-size: 17px; color: var(--muted); margin-top: 28px; line-height: 1.65; animation: fadeUp 0.9s ease 0.25s both; }
  .hero-scroll { position: absolute; bottom: 32px; font-family: var(--mono); font-size: 11px; color: var(--text-dim); letter-spacing: 0.15em; text-transform: uppercase; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }

  .content { max-width: 820px; margin: 0 auto; padding: 0 28px; }
  section { padding: 72px 0; }
  .section-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 12px; display: block; }
  h2 { font-family: var(--serif); font-size: clamp(28px, 4.5vw, 48px); font-weight: 400; line-height: 1.1; margin-bottom: 24px; color: var(--cream); }
  h2 em { font-style: italic; color: var(--green); }
  p { font-size: 16px; color: var(--text); margin-bottom: 16px; line-height: 1.75; }
  strong { color: var(--cream); font-weight: 600; }
  code { font-family: var(--mono); font-size: 13px; background: var(--surface2); padding: 2px 8px; border-radius: 4px; color: var(--green); }
  .divider { width: 48px; height: 1px; background: var(--border); margin: 0 auto; }

  /* TIMELINE */
  .timeline { margin: 36px 0; position: relative; }
  .timeline::before { content: ''; position: absolute; left: 20px; top: 0; bottom: 0; width: 1px; background: var(--border); }
  .tl-item { display: flex; gap: 20px; margin-bottom: 0; padding: 20px 0; position: relative; }
  .tl-item + .tl-item { border-top: 1px solid var(--border); }
  .tl-dot { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative; z-index: 1; }
  .tl-dot.action { background: var(--green-dim); border: 1px solid rgba(34,197,94,0.25); }
  .tl-dot.timeout { background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.25); }
  .tl-dot.idle { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); }
  .tl-dot svg { width: 18px; height: 18px; }
  .tl-dot.action svg { color: var(--green); }
  .tl-dot.timeout svg { color: var(--orange); }
  .tl-dot.idle svg { color: var(--red); }
  .tl-body { flex: 1; }
  .tl-time { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 4px; letter-spacing: 0.06em; }
  .tl-title { font-family: var(--mono); font-size: 14px; color: var(--cream); margin-bottom: 4px; }
  .tl-desc { font-size: 14px; color: var(--muted); line-height: 1.5; }

  /* LRU DIAGRAM */
  .lru-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 32px 28px; margin: 36px 0; }
  .lru-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 24px; text-align: center; }
  .lru-row { display: flex; gap: 8px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
  .lru-label { font-family: var(--mono); font-size: 11px; color: var(--muted); width: 80px; text-align: right; flex-shrink: 0; }
  .page-slot { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .page-box { width: 64px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 11px; font-weight: 700; border: 1px solid; }
  .page-box.active { background: var(--green-dim); border-color: rgba(34,197,94,0.3); color: var(--green); }
  .page-box.lru-evict { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: var(--red); }
  .page-box.new { background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.3); color: #93c5fd; }
  .page-box.empty { background: var(--surface2); border-color: var(--border); color: var(--text-dim); }
  .page-time { font-family: var(--mono); font-size: 10px; color: var(--text-dim); }
  .lru-arrow { display: flex; align-items: center; padding: 0 4px; }
  .lru-arrow svg { color: var(--border); width: 16px; height: 16px; }
  .lru-note { font-family: var(--mono); font-size: 12px; color: var(--muted); text-align: center; margin-top: 8px; padding-top: 16px; border-top: 1px solid var(--border); }

  /* CONFIG TABLE */
  .cfg-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 28px 0; border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
  .cfg-table th { background: var(--surface); padding: 12px 18px; text-align: left; font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--border); }
  .cfg-table td { padding: 14px 18px; font-size: 14px; border-bottom: 1px solid var(--border); background: var(--bg); }
  .cfg-table tr:last-child td { border-bottom: none; }
  .cfg-table td:first-child { font-family: var(--mono); font-size: 13px; color: var(--green); }
  .cfg-table td:nth-child(2) { font-family: var(--mono); font-size: 13px; color: #93c5fd; }
  .cfg-table td:last-child { color: var(--muted); }

  /* REFSTORE */
  .refstore-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 32px 28px; margin: 36px 0; }
  .rs-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-align: center; margin-bottom: 24px; }
  .rs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--border); border-radius: 12px; overflow: hidden; }
  @media(max-width:600px){ .rs-grid{grid-template-columns:1fr;} }
  .rs-cell { background: var(--bg); padding: 20px 16px; text-align: center; }
  .rs-event { font-family: var(--mono); font-size: 11px; color: var(--green); margin-bottom: 8px; letter-spacing: 0.04em; }
  .rs-action { font-size: 13px; color: var(--text); }

  /* CODE BLOCK */
  .code-block { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin: 28px 0; }
  .code-block-header { padding: 10px 18px; border-bottom: 1px solid var(--border); font-family: var(--mono); font-size: 11px; color: var(--muted); display: flex; align-items: center; gap: 8px; }
  .code-block-header .lang-tag { background: var(--green-dim); color: var(--green); padding: 2px 8px; border-radius: 4px; font-size: 10px; }
  .code-block pre { padding: 20px; font-family: var(--mono); font-size: 13px; line-height: 1.65; color: var(--text); overflow-x: auto; }
  .code-block .kw { color: var(--green); }
  .code-block .cm { color: var(--text-dim); font-style: italic; }
  .code-block .fn { color: #93c5fd; }
  .code-block .num { color: var(--orange); }

  @media(max-width:600px){ .content{padding:0 16px;} section{padding:48px 0;} .lru-label{width:50px;} }
</style>
</head>
<body>

<a href="/" class="float-home" title="Home">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
</a>

<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('vi')">VI</button>
  <button class="lang-btn" onclick="setLang('en')">EN</button>
  <button class="lang-btn" onclick="setLang('zh')">中文</button>
  <button class="lang-btn" onclick="setLang('ja')">日本語</button>
</div>

<section class="hero">
  <div class="hero-version">
    <span class="dot"></span>
    <span>GoClaw v2.17.0 · March 25, 2026</span>
  </div>
  <h1 data-vi="Kiểm soát tài nguyên <em>Browser Automation</em>" data-en="Taming <em>Browser Automation</em> Resources" data-zh="驯服<em>浏览器自动化</em>资源" data-ja="ブラウザ自動化<em>リソース制御</em>">Kiểm soát tài nguyên <em>Browser Automation</em></h1>
  <p class="hero-sub" data-vi="Timeout 30 giây mỗi action, tự đóng sau 10 phút idle, tối đa 5 trang mỗi tenant với LRU eviction — v2.17.0 biến browser tool thành công cụ production-ready." data-en="30s per-action timeout, auto-close after 10 min idle, max 5 pages per tenant with LRU eviction — v2.17.0 makes the browser tool production-ready." data-zh="每个操作 30 秒超时、10 分钟空闲后自动关闭、每个租户最多 5 个页面并使用 LRU 驱逐 — v2.17.0 让浏览器工具生产就绪。" data-ja="アクションごとに 30 秒タイムアウト、10 分アイドル後の自動クローズ、LRU エビクション付きテナントあたり最大 5 ページ — v2.17.0 でブラウザツールが本番環境対応になります。">Timeout 30 giây mỗi action, tự đóng sau 10 phút idle, tối đa 5 trang mỗi tenant với LRU eviction — v2.17.0 biến browser tool thành công cụ production-ready.</p>
  <div class="hero-scroll">scroll</div>
</section>

<div class="content">
  <section>
    <span class="section-label" data-vi="Vấn đề" data-en="The Problem" data-zh="问题" data-ja="問題">Vấn đề</span>
    <h2 data-vi="Browser sessions <em>không được kiểm soát</em>" data-en="Browser sessions <em>running wild</em>" data-zh="浏览器会话<em>失控</em>" data-ja="制御されない<em>ブラウザセッション</em>">Browser sessions <em>không được kiểm soát</em></h2>
    <p data-vi="Trước v2.17.0, mỗi agent có thể mở vô số tab Chrome, các action bị treo có thể chạy mãi, và không có cơ chế giải phóng bộ nhớ khi session kết thúc. Trong môi trường multi-tenant, đây là công thức thảm họa." data-en="Before v2.17.0, agents could open unlimited Chrome tabs, hung actions would run forever, and no cleanup happened when sessions ended. In a multi-tenant environment, this was a recipe for disaster." data-zh="在 v2.17.0 之前，代理可以打开无限数量的 Chrome 标签页，挂起的操作会永久运行，会话结束时也没有清理机制。在多租户环境中，这是灾难的配方。" data-ja="v2.17.0 以前は、エージェントが無制限の Chrome タブを開き、ハングしたアクションが永久に実行され、セッション終了時にクリーンアップが行われませんでした。マルチテナント環境では、これは災害の元でした。">Trước v2.17.0, mỗi agent có thể mở vô số tab Chrome, các action bị treo có thể chạy mãi, và không có cơ chế giải phóng bộ nhớ khi session kết thúc. Trong môi trường multi-tenant, đây là công thức thảm họa.</p>

    <div class="timeline">
      <div class="tl-item">
        <div class="tl-dot action">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="tl-body">
          <div class="tl-time" data-vi="T+0s — Bắt đầu action" data-en="T+0s — Action starts" data-zh="T+0s — 操作开始" data-ja="T+0s — アクション開始">T+0s — Bắt đầu action</div>
          <div class="tl-title">browser_navigate("https://example.com")</div>
          <div class="tl-desc" data-vi="Agent gọi browser tool, trang bắt đầu load" data-en="Agent calls browser tool, page starts loading" data-zh="代理调用浏览器工具，页面开始加载" data-ja="エージェントがブラウザツールを呼び出し、ページの読み込み開始">Agent gọi browser tool, trang bắt đầu load</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-dot timeout">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="tl-body">
          <div class="tl-time" data-vi="T+30s — Timeout kích hoạt" data-en="T+30s — Timeout fires" data-zh="T+30s — 超时触发" data-ja="T+30s — タイムアウト発動">T+30s — Timeout kích hoạt</div>
          <div class="tl-title" data-vi="actionTimeout = 30s (có thể cấu hình)" data-en="actionTimeout = 30s (configurable)" data-zh="actionTimeout = 30s（可配置）" data-ja="actionTimeout = 30s（設定可能）">actionTimeout = 30s (có thể cấu hình)</div>
          <div class="tl-desc" data-vi="Context bị hủy, action trả về lỗi rõ ràng thay vì treo mãi" data-en="Context cancelled, action returns a clear error instead of hanging" data-zh="上下文被取消，操作返回明确错误而不是挂起" data-ja="コンテキストがキャンセルされ、アクションはハングせずに明確なエラーを返す">Context bị hủy, action trả về lỗi rõ ràng thay vì treo mãi</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-dot idle">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div class="tl-body">
          <div class="tl-time" data-vi="T+10min — Idle reaper" data-en="T+10min — Idle reaper" data-zh="T+10min — 空闲回收器" data-ja="T+10min — アイドルリーパー">T+10min — Idle reaper</div>
          <div class="tl-title">idleTimeout = 10min → page.Close()</div>
          <div class="tl-desc" data-vi="Reaper goroutine quét mỗi 60s, đóng trang không dùng, giải phóng RAM" data-en="Reaper goroutine scans every 60s, closes unused pages, frees RAM" data-zh="收割者 goroutine 每 60s 扫描一次，关闭未使用的页面，释放 RAM" data-ja="リーパー goroutine が 60 秒ごとにスキャンし、未使用ページを閉じて RAM を解放">Reaper goroutine quét mỗi 60s, đóng trang không dùng, giải phóng RAM</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section>
    <span class="section-label" data-vi="LRU Eviction" data-en="LRU Eviction" data-zh="LRU 驱逐" data-ja="LRU エビクション">LRU Eviction</span>
    <h2 data-vi="Tối đa <em>5 trang</em> mỗi tenant" data-en="Max <em>5 pages</em> per tenant" data-zh="每个租户最多<em>5 个页面</em>" data-ja="テナントあたり最大<em>5 ページ</em>">Tối đa <em>5 trang</em> mỗi tenant</h2>
    <p data-vi="Khi agent cố mở trang thứ 6, GoClaw áp dụng LRU eviction: trang ít được dùng gần nhất sẽ bị đóng trước. Điều này giữ cho tổng số tab Chrome trong tầm kiểm soát dù có bao nhiêu agent chạy đồng thời." data-en="When an agent tries to open a 6th page, GoClaw applies LRU eviction: the least recently used page is closed first. This keeps the total Chrome tab count manageable no matter how many agents run concurrently." data-zh="当代理尝试打开第 6 个页面时，GoClaw 应用 LRU 驱逐：最近最少使用的页面首先被关闭。无论有多少代理并发运行，这都能保持 Chrome 标签总数可控。" data-ja="エージェントが 6 番目のページを開こうとすると、GoClaw は LRU エビクションを適用します：最近最も使われていないページが最初に閉じられます。これにより、何個のエージェントが同時に実行されていても、Chrome タブの総数を管理可能に保ちます。">Khi agent cố mở trang thứ 6, GoClaw áp dụng LRU eviction: trang ít được dùng gần nhất sẽ bị đóng trước. Điều này giữ cho tổng số tab Chrome trong tầm kiểm soát dù có bao nhiêu agent chạy đồng thời.</p>

    <div class="lru-wrap">
      <div class="lru-title" data-vi="Tenant A — Đang có 5 trang, mở trang mới" data-en="Tenant A — 5 pages open, new page requested" data-zh="租户 A — 已有 5 个页面，请求新页面" data-ja="テナント A — 5 ページが開いている状態で新規ページをリクエスト">Tenant A — Đang có 5 trang, mở trang mới</div>
      <div class="lru-row">
        <div class="lru-label" data-vi="Trước:" data-en="Before:" data-zh="之前：" data-ja="前：">Trước:</div>
        <div class="page-slot"><div class="page-box active">P1</div><div class="page-time">8m ago</div></div>
        <div class="page-slot"><div class="page-box lru-evict">P2</div><div class="page-time">9m ago ← LRU</div></div>
        <div class="page-slot"><div class="page-box active">P3</div><div class="page-time">2m ago</div></div>
        <div class="page-slot"><div class="page-box active">P4</div><div class="page-time">1m ago</div></div>
        <div class="page-slot"><div class="page-box active">P5</div><div class="page-time">30s ago</div></div>
      </div>
      <div class="lru-row">
        <div class="lru-label" data-vi="Sau:" data-en="After:" data-zh="之后：" data-ja="後：">Sau:</div>
        <div class="page-slot"><div class="page-box active">P1</div><div class="page-time">8m ago</div></div>
        <div class="page-slot"><div class="page-box empty">—</div><div class="page-time">evicted</div></div>
        <div class="page-slot"><div class="page-box active">P3</div><div class="page-time">2m ago</div></div>
        <div class="page-slot"><div class="page-box active">P4</div><div class="page-time">1m ago</div></div>
        <div class="page-slot"><div class="page-box active">P5</div><div class="page-time">30s ago</div></div>
        <div class="lru-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></div>
        <div class="page-slot"><div class="page-box new">P6</div><div class="page-time">new</div></div>
      </div>
      <div class="lru-note" data-vi="P2 bị evict (9 phút không dùng) → P6 được cấp phát · RefStore.Remove(P2) được gọi" data-en="P2 evicted (9 min unused) → P6 allocated · RefStore.Remove(P2) called" data-zh="P2 被驱逐（9 分钟未使用）→ P6 被分配 · RefStore.Remove(P2) 被调用" data-ja="P2 がエビクト（9分間未使用）→ P6 が割り当て · RefStore.Remove(P2) が呼び出される">P2 bị evict (9 phút không dùng) → P6 được cấp phát · RefStore.Remove(P2) được gọi</div>
    </div>
  </section>

  <div class="divider"></div>

  <section>
    <span class="section-label" data-vi="RefStore" data-en="RefStore Cleanup" data-zh="RefStore 清理" data-ja="RefStore クリーンアップ">RefStore</span>
    <h2 data-vi="Không để lại <em>memory leak</em>" data-en="No <em>memory leaks</em> left behind" data-zh="不留下<em>内存泄漏</em>" data-ja="メモリリークを<em>残さない</em>">Không để lại <em>memory leak</em></h2>
    <p data-vi="RefStore theo dõi tất cả các tham chiếu đến DOM elements, event listeners, và context của mỗi trang. Khi trang bị đóng — dù bởi agent, idle reaper, hay LRU eviction — RefStore.Remove() được gọi để dọn sạch." data-en="RefStore tracks all references to DOM elements, event listeners, and context for each page. When a page closes — whether by agent, idle reaper, or LRU eviction — RefStore.Remove() is called to clean up." data-zh="RefStore 跟踪每个页面的所有 DOM 元素引用、事件监听器和上下文。当页面关闭时（无论是代理、空闲回收器还是 LRU 驱逐），都会调用 RefStore.Remove() 进行清理。" data-ja="RefStore は各ページの DOM 要素参照、イベントリスナー、コンテキストをすべて追跡します。ページが閉じられるとき（エージェント、アイドルリーパー、LRU エビクションのいずれかによる場合）、RefStore.Remove() がクリーンアップのために呼び出されます。">RefStore theo dõi tất cả các tham chiếu đến DOM elements, event listeners, và context của mỗi trang. Khi trang bị đóng — dù bởi agent, idle reaper, hay LRU eviction — RefStore.Remove() được gọi để dọn sạch.</p>

    <div class="refstore-wrap">
      <div class="rs-title" data-vi="RefStore cleanup được gọi bởi 3 nguồn" data-en="RefStore cleanup triggered by 3 sources" data-zh="RefStore 清理由 3 个来源触发" data-ja="RefStore クリーンアップは 3 つのソースから呼び出される">RefStore cleanup được gọi bởi 3 nguồn</div>
      <div class="rs-grid">
        <div class="rs-cell">
          <div class="rs-event">page.Close()</div>
          <div class="rs-action" data-vi="Agent chủ động đóng trang sau khi xong việc" data-en="Agent explicitly closes page after completing task" data-zh="代理在完成任务后主动关闭页面" data-ja="エージェントがタスク完了後にページを明示的に閉じる">Agent chủ động đóng trang sau khi xong việc</div>
        </div>
        <div class="rs-cell">
          <div class="rs-event">LRU evict</div>
          <div class="rs-action" data-vi="maxPages vượt ngưỡng, trang LRU bị thu hồi" data-en="maxPages exceeded, LRU page reclaimed" data-zh="超过 maxPages，LRU 页面被回收" data-ja="maxPages を超えると LRU ページが回収される">maxPages vượt ngưỡng, trang LRU bị thu hồi</div>
        </div>
        <div class="rs-cell">
          <div class="rs-event">reapIdlePages()</div>
          <div class="rs-action" data-vi="Goroutine quét mỗi 60s, đóng trang idle > 10min" data-en="Goroutine scans every 60s, closes pages idle > 10min" data-zh="Goroutine 每 60 秒扫描一次，关闭空闲 > 10 分钟的页面" data-ja="Goroutine が 60 秒ごとにスキャンし、10 分以上アイドルのページを閉じる">Goroutine quét mỗi 60s, đóng trang idle &gt; 10min</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section>
    <span class="section-label" data-vi="Cấu hình" data-en="Configuration" data-zh="配置" data-ja="設定">Cấu hình</span>
    <h2 data-vi="Tùy chỉnh <em>theo workload</em>" data-en="Tune for <em>your workload</em>" data-zh="针对<em>您的工作负载</em>调优" data-ja="<em>ワークロード</em>に合わせてチューニング">Tùy chỉnh <em>theo workload</em></h2>

    <table class="cfg-table">
      <thead>
        <tr>
          <th data-vi="Tùy chọn" data-en="Option" data-zh="选项" data-ja="オプション">Tùy chọn</th>
          <th data-vi="Mặc định" data-en="Default" data-zh="默认值" data-ja="デフォルト">Mặc định</th>
          <th data-vi="Mô tả" data-en="Description" data-zh="描述" data-ja="説明">Mô tả</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>WithActionTimeout</td>
          <td>30s</td>
          <td data-vi="Timeout mỗi thao tác browser (navigate, click, fill…)" data-en="Timeout per browser action (navigate, click, fill…)" data-zh="每个浏览器操作的超时（导航、点击、填写…）" data-ja="ブラウザアクションごとのタイムアウト（ナビゲート、クリック、入力…）">Timeout mỗi thao tác browser (navigate, click, fill…)</td>
        </tr>
        <tr>
          <td>WithIdleTimeout</td>
          <td>10min</td>
          <td data-vi="Thời gian idle trước khi tự đóng trang. 0 = vô hiệu hóa." data-en="Idle time before auto-closing a page. 0 = disabled." data-zh="自动关闭页面之前的空闲时间。0 = 禁用。" data-ja="ページを自動クローズするまでのアイドル時間。0 = 無効。">Thời gian idle trước khi tự đóng trang. 0 = vô hiệu hóa.</td>
        </tr>
        <tr>
          <td>WithMaxPages</td>
          <td>5</td>
          <td data-vi="Số trang tối đa mỗi tenant. Vượt ngưỡng → LRU eviction." data-en="Max pages per tenant. Exceeding triggers LRU eviction." data-zh="每个租户的最大页面数。超过限制触发 LRU 驱逐。" data-ja="テナントあたりの最大ページ数。超過すると LRU エビクションが発生。">Số trang tối đa mỗi tenant. Vượt ngưỡng → LRU eviction.</td>
        </tr>
      </tbody>
    </table>

    <div class="code-block">
      <div class="code-block-header">
        <span class="lang-tag">Go</span>
        <span>pkg/browser/browser.go · defaults</span>
      </div>
      <pre>m := &amp;Manager{
  actionTimeout: <span class="num">30</span> * time.Second,
  idleTimeout:   <span class="num">10</span> * time.Minute,
  maxPages:      <span class="num">5</span>,
}</pre>
    </div>
  </section>
</div>

<script>
function setLang(lang) {
  document.querySelectorAll('[data-vi],[data-en],[data-zh],[data-ja]').forEach(el => {
    const val = el.getAttribute('data-' + lang);
    if (val) el.innerHTML = val;
  });
  document.querySelectorAll('.lang-btn').forEach(b => {
    b.classList.toggle('active', b.textContent.toLowerCase() === lang || (lang === 'zh' && b.textContent === '中文') || (lang === 'ja' && b.textContent === '日本語'));
  });
  document.documentElement.lang = lang;
  localStorage.setItem('gc-lang', lang);
}
const saved = localStorage.getItem('gc-lang');
if (saved && saved !== 'vi') setLang(saved);
</script>
</body>
</html>
`;
