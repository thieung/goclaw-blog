---
// Draft: semantic-memory-chunk-overlap — raw HTML preserved
const rawHtml = `<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>GoClaw v2.19.0 — Semantic Memory với Chunk Overlap</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1208;
    --bg: #16110a;
    --surface: #211810;
    --surface2: #2c1f12;
    --border: #3d2c1a;
    --amber: #d97706;
    --amber-light: #f59e0b;
    --amber-dim: rgba(217,119,6,0.15);
    --amber-glow: rgba(217,119,6,0.08);
    --brown: #92400e;
    --cream: #fdf6e3;
    --muted: #a07a50;
    --text: #e8d5b0;
    --text-dim: #8a6a40;
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }

  /* FLOAT HOME */
  .float-home { position: fixed; bottom: 24px; left: 24px; z-index: 100; width: 44px; height: 44px; border-radius: 12px; background: rgba(33,24,16,0.9); backdrop-filter: blur(12px); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; transition: all 0.25s; box-shadow: 0 4px 16px rgba(0,0,0,0.5); }
  .float-home:hover { background: var(--amber); color: var(--ink); border-color: transparent; transform: translateY(-2px); }
  .float-home svg { width: 18px; height: 18px; }

  /* LANG SWITCHER */
  .lang-bar { position: fixed; top: 20px; right: 20px; z-index: 100; display: flex; gap: 4px; background: rgba(33,24,16,0.9); backdrop-filter: blur(12px); border: 1px solid var(--border); border-radius: 10px; padding: 4px; }
  .lang-btn { padding: 5px 12px; border-radius: 7px; font-family: var(--mono); font-size: 11px; cursor: pointer; border: none; background: transparent; color: var(--muted); transition: all 0.2s; }
  .lang-btn.active { background: var(--amber); color: var(--ink); font-weight: 700; }

  /* HERO */
  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 80px 24px 60px; position: relative; overflow: hidden; background: var(--bg); }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 30%, rgba(217,119,6,0.12) 0%, transparent 60%); pointer-events: none; }
  .hero-version { display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; border: 1px solid var(--border); border-radius: 100px; font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 36px; letter-spacing: 0.04em; backdrop-filter: blur(10px); animation: fadeUp 0.8s ease both; }
  .hero-version .dot { width: 7px; height: 7px; background: var(--amber); border-radius: 50%; animation: blink 2.5s infinite; }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
  .hero h1 { font-family: var(--serif); font-size: clamp(40px, 7vw, 88px); font-weight: 400; line-height: 1.05; color: var(--cream); max-width: 860px; animation: fadeUp 0.9s ease 0.1s both; }
  .hero h1 em { font-style: italic; color: var(--amber-light); }
  .hero-sub { max-width: 580px; font-size: 17px; color: var(--muted); margin-top: 28px; line-height: 1.65; animation: fadeUp 0.9s ease 0.25s both; }
  .hero-scroll { position: absolute; bottom: 32px; font-family: var(--mono); font-size: 11px; color: var(--text-dim); letter-spacing: 0.15em; text-transform: uppercase; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }

  /* CONTENT */
  .content { max-width: 820px; margin: 0 auto; padding: 0 28px; }
  section { padding: 72px 0; }
  .section-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber); margin-bottom: 12px; display: block; }
  h2 { font-family: var(--serif); font-size: clamp(28px, 4.5vw, 48px); font-weight: 400; line-height: 1.1; margin-bottom: 24px; color: var(--cream); }
  h2 em { font-style: italic; color: var(--amber-light); }
  p { font-size: 16px; color: var(--text); margin-bottom: 16px; line-height: 1.75; }
  strong { color: var(--cream); font-weight: 600; }
  code { font-family: var(--mono); font-size: 13px; background: var(--surface2); padding: 2px 8px; border-radius: 4px; color: var(--amber-light); }
  .divider { width: 48px; height: 1px; background: var(--border); margin: 0 auto; }

  /* CHUNK VISUAL */
  .chunk-demo { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; margin: 40px 0; }
  .chunk-demo-header { padding: 16px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .chunk-demo-header span { font-family: var(--mono); font-size: 12px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
  .chunk-scenario { padding: 28px 24px; }
  .chunk-scenario + .chunk-scenario { border-top: 1px solid var(--border); }
  .chunk-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 16px; }
  .chunk-label.bad { color: #ef4444; }
  .chunk-label.good { color: #4ade80; }
  .chunk-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
  .chunk-block { padding: 8px 12px; border-radius: 8px; font-family: var(--mono); font-size: 12px; line-height: 1.4; max-width: 220px; }
  .chunk-block.c1 { background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.2); color: #93c5fd; }
  .chunk-block.c2 { background: rgba(168,85,247,0.1); border: 1px solid rgba(168,85,247,0.2); color: #c4b5fd; }
  .chunk-block.c3 { background: rgba(236,72,153,0.1); border: 1px solid rgba(236,72,153,0.2); color: #f9a8d4; }
  .chunk-block.overlap { background: rgba(217,119,6,0.12); border: 1px solid rgba(217,119,6,0.25); color: var(--amber-light); }
  .chunk-gap { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: #ef4444; }
  .chunk-gap svg { flex-shrink: 0; }
  .overlap-band { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--amber-light); margin-top: 8px; }
  .overlap-band svg { flex-shrink: 0; }

  /* CONFIG CARD */
  .config-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 32px 0; }
  @media(max-width:600px){ .config-grid{grid-template-columns:1fr;} }
  .config-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
  .config-card .cfg-key { font-family: var(--mono); font-size: 12px; color: var(--amber); margin-bottom: 6px; }
  .config-card .cfg-val { font-family: var(--mono); font-size: 28px; font-weight: 700; color: var(--cream); margin-bottom: 6px; }
  .config-card .cfg-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }

  /* CODE BLOCK */
  .code-block { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin: 28px 0; }
  .code-block-header { padding: 10px 18px; border-bottom: 1px solid var(--border); font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.1em; display: flex; align-items: center; gap: 8px; }
  .code-block-header .lang-tag { background: var(--amber-dim); color: var(--amber); padding: 2px 8px; border-radius: 4px; font-size: 10px; }
  .code-block pre { padding: 20px 20px; font-family: var(--mono); font-size: 13px; line-height: 1.65; color: var(--text); overflow-x: auto; tab-size: 2; }
  .code-block .kw { color: var(--amber-light); }
  .code-block .cm { color: var(--text-dim); font-style: italic; }
  .code-block .fn { color: #93c5fd; }
  .code-block .num { color: #4ade80; }
  .code-block .str { color: #f9a8d4; }

  /* FLOW DIAGRAM */
  .flow-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 36px 28px; margin: 36px 0; }
  .flow-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-align: center; margin-bottom: 28px; }
  .flow-steps { display: flex; flex-direction: column; gap: 0; }
  .flow-step { display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; }
  .flow-step + .flow-step { border-top: 1px solid var(--border); }
  .flow-step-num { width: 32px; height: 32px; border-radius: 8px; background: var(--amber-dim); border: 1px solid rgba(217,119,6,0.3); display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--amber); flex-shrink: 0; }
  .flow-step-body h4 { font-family: var(--mono); font-size: 14px; color: var(--cream); margin-bottom: 4px; }
  .flow-step-body p { font-size: 14px; color: var(--muted); margin: 0; line-height: 1.5; }

  /* BENEFITS */
  .benefit-list { list-style: none; padding: 0; margin: 24px 0; }
  .benefit-list li { display: flex; align-items: flex-start; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 16px; color: var(--text); }
  .benefit-list li:last-child { border-bottom: none; }
  .benefit-list .bicon { width: 24px; height: 24px; flex-shrink: 0; color: var(--amber); margin-top: 1px; }

  @media(max-width:600px){ .content{padding:0 16px;} section{padding:48px 0;} }
</style>
</head>
<body>

<!-- Float Home -->
<a href="/" class="float-home" title="Home">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
</a>

<!-- Lang Switcher -->
<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('vi')">VI</button>
  <button class="lang-btn" onclick="setLang('en')">EN</button>
  <button class="lang-btn" onclick="setLang('zh')">中文</button>
  <button class="lang-btn" onclick="setLang('ja')">日本語</button>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-version">
    <span class="dot"></span>
    <span>GoClaw v2.19.0 · March 25, 2026</span>
  </div>
  <h1 data-vi="Semantic Memory với <em>Chunk Overlap</em>" data-en="Semantic Memory with <em>Chunk Overlap</em>" data-zh="语义记忆与<em>块重叠</em>" data-ja="セマンティックメモリと<em>チャンクオーバーラップ</em>">Semantic Memory với <em>Chunk Overlap</em></h1>
  <p class="hero-sub" data-vi="Vùng ranh giới giữa các đoạn văn bản luôn là điểm yếu của RAG. v2.19.0 giải quyết bằng cách chồng lấp ngữ cảnh 200 ký tự — không còn mất thông tin tại biên chunk." data-en="Chunk boundaries have always been RAG's blind spot. v2.19.0 fixes this with 200-character context overlap — no more context loss at split points." data-zh="分块边界一直是 RAG 的盲点。v2.19.0 通过 200 字符的上下文重叠解决了这个问题。" data-ja="チャンク境界は RAG の盲点でした。v2.19.0 は 200 文字のコンテキスト重複でこれを解決します。">Vùng ranh giới giữa các đoạn văn bản luôn là điểm yếu của RAG. v2.19.0 giải quyết bằng cách chồng lấp ngữ cảnh 200 ký tự — không còn mất thông tin tại biên chunk.</p>
  <div class="hero-scroll">scroll</div>
</section>

<!-- PROBLEM -->
<div class="content">
  <section>
    <span class="section-label" data-vi="Vấn đề" data-en="The Problem" data-zh="问题" data-ja="問題">Vấn đề</span>
    <h2 data-vi="Ngữ cảnh bị mất tại <em>ranh giới chunk</em>" data-en="Context lost at <em>chunk boundaries</em>" data-zh="在<em>块边界</em>丢失上下文" data-ja="チャンク境界での<em>コンテキスト損失</em>">Ngữ cảnh bị mất tại <em>ranh giới chunk</em></h2>
    <p data-vi="Khi một tài liệu dài được chia thành các chunk để lưu vào vector store, thông tin quan trọng thường nằm đúng ở ranh giới — câu kết thúc chunk A liên kết với câu mở đầu chunk B. Nếu truy vấn semantic chỉ match chunk B, phần kết luận từ chunk A sẽ bị bỏ qua." data-en="When a long document is split into chunks for vector storage, critical information often sits exactly at the boundary — the closing sentence of chunk A connects to the opening of chunk B. If a semantic query only matches chunk B, the context from chunk A's conclusion is lost." data-zh="当长文档被分割成块存入向量存储时，关键信息往往正好位于边界处。如果语义查询只匹配块 B，来自块 A 结论的上下文就会丢失。" data-ja="長いドキュメントをベクターストア用にチャンク分割すると、重要な情報がちょうど境界に位置することがよくあります。セマンティッククエリがチャンク B のみにマッチした場合、チャンク A の結論からのコンテキストが失われます。">Khi một tài liệu dài được chia thành các chunk để lưu vào vector store, thông tin quan trọng thường nằm đúng ở ranh giới — câu kết thúc chunk A liên kết với câu mở đầu chunk B. Nếu truy vấn semantic chỉ match chunk B, phần kết luận từ chunk A sẽ bị bỏ qua.</p>

    <div class="chunk-demo">
      <div class="chunk-demo-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span data-vi="So sánh trực quan: không overlap vs. có overlap" data-en="Visual comparison: no overlap vs. with overlap" data-zh="可视化对比：无重叠 vs. 有重叠" data-ja="視覚的比較：重複なし vs. 重複あり">So sánh trực quan: không overlap vs. có overlap</span>
      </div>

      <div class="chunk-scenario">
        <div class="chunk-label bad" data-vi="Trước v2.19 — Không có overlap" data-en="Before v2.19 — No overlap" data-zh="v2.19 之前 — 无重叠" data-ja="v2.19 以前 — 重複なし">Trước v2.19 — Không có overlap</div>
        <div class="chunk-row">
          <div class="chunk-block c1">...giải thuật tìm kiếm A* hoạt động bằng cách ưu tiên các đường đi có chi phí thấp nhất.</div>
          <div class="chunk-block c2">Phương pháp này hiệu quả hơn BFS khi heuristic chính xác. Trong thực tế...</div>
          <div class="chunk-block c3">...triển khai trên đồ thị lớn cần tối ưu bộ nhớ thêm.</div>
        </div>
        <div class="chunk-gap">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <span data-vi="Query 'A* vs BFS' chỉ match chunk 2 — mất ngữ cảnh từ chunk 1" data-en="Query 'A* vs BFS' only matches chunk 2 — context from chunk 1 is lost" data-zh="查询 'A* vs BFS' 只匹配块 2 — 来自块 1 的上下文丢失" data-ja="クエリ 'A* vs BFS' はチャンク 2 のみにマッチ — チャンク 1 のコンテキストが失われる">Query 'A* vs BFS' chỉ match chunk 2 — mất ngữ cảnh từ chunk 1</span>
        </div>
      </div>

      <div class="chunk-scenario">
        <div class="chunk-label good" data-vi="Sau v2.19 — Overlap 200 ký tự" data-en="After v2.19 — 200-char overlap" data-zh="v2.19 之后 — 200 字符重叠" data-ja="v2.19 以降 — 200 文字の重複">Sau v2.19 — Overlap 200 ký tự</div>
        <div class="chunk-row">
          <div class="chunk-block c1">...giải thuật tìm kiếm A* hoạt động bằng cách ưu tiên các đường đi có chi phí thấp nhất.</div>
          <div class="chunk-block overlap">← overlap từ chunk 1: "...ưu tiên các đường đi có chi phí thấp nhất."</div>
          <div class="chunk-block c2">Phương pháp này hiệu quả hơn BFS khi heuristic chính xác. Trong thực tế...</div>
        </div>
        <div class="overlap-band">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span data-vi="Chunk 2 giờ mang theo đuôi chunk 1 — query match đầy đủ ngữ cảnh" data-en="Chunk 2 now carries the tail of chunk 1 — query gets full context" data-zh="块 2 现在携带块 1 的尾部 — 查询获得完整上下文" data-ja="チャンク 2 がチャンク 1 の末尾を持ち — クエリで完全なコンテキストを取得">Chunk 2 giờ mang theo đuôi chunk 1 — query match đầy đủ ngữ cảnh</span>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- HOW IT WORKS -->
  <section>
    <span class="section-label" data-vi="Cách hoạt động" data-en="How It Works" data-zh="工作原理" data-ja="仕組み">Cách hoạt động</span>
    <h2 data-vi="Thuật toán <em>ChunkText</em>" data-en="The <em>ChunkText</em> Algorithm" data-zh="<em>ChunkText</em> 算法" data-ja="<em>ChunkText</em> アルゴリズム">Thuật toán <em>ChunkText</em></h2>
    <p data-vi="Hàm ChunkText trong GoClaw tách văn bản theo ranh giới đoạn văn, sau đó tính toán các dòng cuối của chunk hiện tại để chèn vào đầu chunk tiếp theo. Overlap bị clamp tối đa bằng maxChunkLen/2 để tránh vòng lặp vô hạn." data-en="GoClaw's ChunkText function splits text at paragraph boundaries, then computes trailing lines from the current chunk to prepend to the next. Overlap is clamped to at most maxChunkLen/2 to prevent infinite loops." data-zh="GoClaw 的 ChunkText 函数在段落边界分割文本，然后计算当前块的尾部行并添加到下一块的开头。重叠被限制在最多 maxChunkLen/2 以防止无限循环。" data-ja="GoClaw の ChunkText 関数は段落境界でテキストを分割し、現在のチャンクの末尾行を計算して次のチャンクの先頭に追加します。無限ループを防ぐためオーバーラップは最大 maxChunkLen/2 に制限されます。">Hàm ChunkText trong GoClaw tách văn bản theo ranh giới đoạn văn, sau đó tính toán các dòng cuối của chunk hiện tại để chèn vào đầu chunk tiếp theo. Overlap bị clamp tối đa bằng maxChunkLen/2 để tránh vòng lặp vô hạn.</p>

    <div class="code-block">
      <div class="code-block-header">
        <span class="lang-tag">Go</span>
        <span>internal/memory/embeddings.go</span>
      </div>
      <pre><span class="cm">// ChunkText splits text into chunks at paragraph boundaries with optional overlap.
// When overlap > 0, trailing lines from the previous chunk are prepended to the next
// so that context at chunk boundaries is preserved for semantic search.</span>
<span class="kw">func</span> <span class="fn">ChunkText</span>(text <span class="kw">string</span>, maxChunkLen, overlap <span class="kw">int</span>) []TextChunk {
  <span class="kw">if</span> maxChunkLen &lt;= <span class="num">0</span> { maxChunkLen = <span class="num">1000</span> }
  <span class="kw">if</span> overlap &lt; <span class="num">0</span>   { overlap = <span class="num">0</span> }
  <span class="cm">// Clamp overlap to half the chunk size to prevent infinite loop</span>
  <span class="kw">if</span> overlap &gt;= maxChunkLen/<span class="num">2</span> {
    overlap = maxChunkLen / <span class="num">2</span>
  }
  <span class="cm">// overlapLines holds trailing lines from previous chunk</span>
  <span class="kw">var</span> overlapLines []<span class="kw">string</span>
  <span class="cm">// ... splits at paragraph boundaries, carries overlap forward</span>
}</pre>
    </div>

    <div class="flow-wrap">
      <div class="flow-title" data-vi="Luồng xử lý embedding với overlap" data-en="Embedding pipeline with overlap" data-zh="带重叠的嵌入处理流程" data-ja="重複ありの埋め込み処理フロー">Luồng xử lý embedding với overlap</div>
      <div class="flow-steps">
        <div class="flow-step">
          <div class="flow-step-num">1</div>
          <div class="flow-step-body">
            <h4 data-vi="Tải tài liệu" data-en="Load document" data-zh="加载文档" data-ja="ドキュメントを読み込む">Tải tài liệu</h4>
            <p data-vi="Nội dung thô từ DB, file, hoặc memory upsert" data-en="Raw content from DB, file, or memory upsert" data-zh="来自 DB、文件或内存更新的原始内容" data-ja="DB、ファイル、またはメモリ更新からの生コンテンツ">Nội dung thô từ DB, file, hoặc memory upsert</p>
          </div>
        </div>
        <div class="flow-step">
          <div class="flow-step-num">2</div>
          <div class="flow-step-body">
            <h4>ChunkText(content, chunkLen, chunkOverlap)</h4>
            <p data-vi="Chia theo ranh giới đoạn văn, chèn overlap từ chunk trước" data-en="Split at paragraph boundaries, prepend overlap from previous chunk" data-zh="在段落边界分割，从上一块添加重叠内容" data-ja="段落境界で分割し、前のチャンクからの重複を先頭に追加">Chia theo ranh giới đoạn văn, chèn overlap từ chunk trước</p>
          </div>
        </div>
        <div class="flow-step">
          <div class="flow-step-num">3</div>
          <div class="flow-step-body">
            <h4 data-vi="Embedding từng chunk" data-en="Embed each chunk" data-zh="嵌入每个块" data-ja="各チャンクを埋め込む">Embedding từng chunk</h4>
            <p data-vi="Gọi provider API (OpenAI, Gemini...) lấy vector 1536 chiều" data-en="Call provider API (OpenAI, Gemini...) for 1536-dim vector" data-zh="调用提供商 API（OpenAI、Gemini...）获取 1536 维向量" data-ja="プロバイダー API（OpenAI、Gemini...）を呼び出し 1536 次元ベクターを取得">Gọi provider API (OpenAI, Gemini...) lấy vector 1536 chiều</p>
          </div>
        </div>
        <div class="flow-step">
          <div class="flow-step-num">4</div>
          <div class="flow-step-body">
            <h4 data-vi="Lưu vào pgvector / SQLite" data-en="Store in pgvector / SQLite" data-zh="存入 pgvector / SQLite" data-ja="pgvector / SQLite に保存">Lưu vào pgvector / SQLite</h4>
            <p data-vi="Mỗi chunk có StartLine, EndLine để truy nguyên nguồn gốc" data-en="Each chunk carries StartLine, EndLine for source attribution" data-zh="每个块携带 StartLine、EndLine 用于来源追溯" data-ja="各チャンクはソース追跡のために StartLine、EndLine を持つ">Mỗi chunk có StartLine, EndLine để truy nguyên nguồn gốc</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONFIG -->
  <section>
    <span class="section-label" data-vi="Cấu hình" data-en="Configuration" data-zh="配置" data-ja="設定">Cấu hình</span>
    <h2 data-vi="Cài đặt <em>per-agent</em>" data-en="Per-agent <em>settings</em>" data-zh="<em>每个代理</em>的设置" data-ja="エージェントごとの<em>設定</em>">Cài đặt <em>per-agent</em></h2>
    <p data-vi="Các thông số chunk được lưu trong system_configs table và áp dụng per-tenant. Bạn có thể ghi đè cho từng agent riêng lẻ qua UI hoặc config." data-en="Chunk parameters are stored in the system_configs table and applied per-tenant. Override per-agent via UI or config." data-zh="块参数存储在 system_configs 表中并按租户应用。可通过 UI 或配置按代理覆盖。" data-ja="チャンクパラメータは system_configs テーブルに保存されテナントごとに適用されます。UI または設定でエージェントごとに上書き可能です。">Các thông số chunk được lưu trong system_configs table và áp dụng per-tenant. Bạn có thể ghi đè cho từng agent riêng lẻ qua UI hoặc config.</p>

    <div class="config-grid">
      <div class="config-card">
        <div class="cfg-key">embedding.max_chunk_len</div>
        <div class="cfg-val">1000</div>
        <div class="cfg-desc" data-vi="Số ký tự tối đa mỗi chunk. Tăng lên cho tài liệu dài, giảm để tìm kiếm chi tiết hơn." data-en="Max characters per chunk. Increase for long documents, decrease for more granular search." data-zh="每块最大字符数。长文档可增大，精细搜索可减小。" data-ja="チャンクあたりの最大文字数。長いドキュメントには増やし、細かい検索には減らします。">Số ký tự tối đa mỗi chunk. Tăng lên cho tài liệu dài, giảm để tìm kiếm chi tiết hơn.</div>
      </div>
      <div class="config-card">
        <div class="cfg-key">embedding.chunk_overlap</div>
        <div class="cfg-val">200</div>
        <div class="cfg-desc" data-vi="Số ký tự overlap giữa các chunk liền kề. Mặc định 200 — tối ưu cho hầu hết tài liệu kỹ thuật." data-en="Characters of overlap between adjacent chunks. Default 200 — optimal for most technical documents." data-zh="相邻块之间的重叠字符数。默认 200 — 适用于大多数技术文档。" data-ja="隣接チャンク間の重複文字数。デフォルト 200 — ほとんどの技術文書に最適。">Số ký tự overlap giữa các chunk liền kề. Mặc định 200 — tối ưu cho hầu hết tài liệu kỹ thuật.</div>
      </div>
    </div>

    <p data-vi="Giá trị overlap bị tự động clamp xuống tối đa <code>maxChunkLen / 2</code> để đảm bảo mỗi chunk luôn chứa nội dung mới, tránh duplicate embedding và vòng lặp vô hạn." data-en="The overlap value is automatically clamped to at most <code>maxChunkLen / 2</code> to ensure each chunk always contains new content, preventing duplicate embeddings and infinite loops." data-zh="重叠值自动限制在最多 <code>maxChunkLen / 2</code>，确保每个块始终包含新内容，防止重复嵌入和无限循环。" data-ja="重複値は自動的に <code>maxChunkLen / 2</code> 以下に制限され、各チャンクが常に新しいコンテンツを含むことを保証し、重複埋め込みと無限ループを防ぎます。">Giá trị overlap bị tự động clamp xuống tối đa <code>maxChunkLen / 2</code> để đảm bảo mỗi chunk luôn chứa nội dung mới, tránh duplicate embedding và vòng lặp vô hạn.</p>
  </section>

  <div class="divider"></div>

  <!-- BENEFITS -->
  <section>
    <span class="section-label" data-vi="Tác động" data-en="Impact" data-zh="影响" data-ja="影響">Tác động</span>
    <h2 data-vi="Tại sao điều này <em>quan trọng</em>" data-en="Why this <em>matters</em>" data-zh="为什么这<em>很重要</em>" data-ja="なぜ<em>重要</em>なのか">Tại sao điều này <em>quan trọng</em></h2>

    <ul class="benefit-list">
      <li>
        <svg class="bicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <span data-vi="<strong>Giảm hallucination:</strong> Agent nhận đủ ngữ cảnh tại biên chunk, không phải tự đoán phần bị thiếu." data-en="<strong>Less hallucination:</strong> Agents receive complete context at chunk boundaries instead of guessing missing parts." data-zh="<strong>减少幻觉：</strong>代理在块边界处获得完整上下文，而不是猜测缺失部分。" data-ja="<strong>幻覚の減少：</strong>エージェントはチャンク境界で完全なコンテキストを受け取り、欠けている部分を推測しません。"><strong>Giảm hallucination:</strong> Agent nhận đủ ngữ cảnh tại biên chunk, không phải tự đoán phần bị thiếu.</span>
      </li>
      <li>
        <svg class="bicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span data-vi="<strong>Cải thiện recall:</strong> Query nằm giữa hai chunk vẫn được retrieve đúng nhờ overlap chứa cả hai bên ranh giới." data-en="<strong>Better recall:</strong> Queries spanning two chunks are still retrieved correctly because overlap captures both sides of the boundary." data-zh="<strong>更好的召回：</strong>跨越两个块的查询仍能正确检索，因为重叠捕获了边界两侧的内容。" data-ja="<strong>より良い再現率：</strong>2つのチャンクにまたがるクエリも、重複が境界の両側をキャプチャするため正しく取得されます。"><strong>Cải thiện recall:</strong> Query nằm giữa hai chunk vẫn được retrieve đúng nhờ overlap chứa cả hai bên ranh giới.</span>
      </li>
      <li>
        <svg class="bicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span data-vi="<strong>Không cần thay đổi schema:</strong> Tính năng được tích hợp hoàn toàn trong tầng chunking — pgvector schema không đổi." data-en="<strong>No schema change needed:</strong> The feature is fully contained in the chunking layer — pgvector schema is unchanged." data-zh="<strong>无需更改 schema：</strong>该功能完全包含在分块层中 — pgvector schema 保持不变。" data-ja="<strong>スキーマ変更不要：</strong>機能はチャンキング層に完全に含まれ、pgvector スキーマは変更されません。"><strong>Không cần thay đổi schema:</strong> Tính năng được tích hợp hoàn toàn trong tầng chunking — pgvector schema không đổi.</span>
      </li>
      <li>
        <svg class="bicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        <span data-vi="<strong>Cấu hình linh hoạt:</strong> Per-agent override cho phép agent chuyên biệt (code, legal, medical) dùng chunk size phù hợp với domain." data-en="<strong>Flexible configuration:</strong> Per-agent overrides let specialized agents (code, legal, medical) use domain-appropriate chunk sizes." data-zh="<strong>灵活配置：</strong>每个代理的覆盖允许专业代理（代码、法律、医疗）使用适合领域的块大小。" data-ja="<strong>柔軟な設定：</strong>エージェントごとの上書きにより、専門エージェント（コード、法律、医療）がドメインに適したチャンクサイズを使用できます。"><strong>Cấu hình linh hoạt:</strong> Per-agent override cho phép agent chuyên biệt (code, legal, medical) dùng chunk size phù hợp với domain.</span>
      </li>
    </ul>
  </section>
</div>

<script>
const i18n = {
  vi: document.querySelectorAll('[data-vi]'),
  en: document.querySelectorAll('[data-en]'),
  zh: document.querySelectorAll('[data-zh]'),
  ja: document.querySelectorAll('[data-ja]')
};
function setLang(lang) {
  document.querySelectorAll('[data-vi],[data-en],[data-zh],[data-ja]').forEach(el => {
    const val = el.getAttribute('data-' + lang);
    if (val) el.innerHTML = val;
  });
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.textContent.toLowerCase() === lang || (lang === 'zh' && b.textContent === '中文') || (lang === 'ja' && b.textContent === '日本語')));
  document.documentElement.lang = lang;
  localStorage.setItem('gc-lang', lang);
}
const saved = localStorage.getItem('gc-lang');
if (saved && saved !== 'vi') setLang(saved);
// Pool bar animation
window.addEventListener('load', () => {
  document.querySelectorAll('.pool-bar-fill').forEach(b => {
    const w = b.style.width; b.style.width = '0';
    setTimeout(() => b.style.width = w, 300);
  });
});
</script>
</body>
</html>
`;
