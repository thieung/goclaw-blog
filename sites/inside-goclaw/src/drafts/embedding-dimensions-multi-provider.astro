---
// Draft: embedding-dimensions-multi-provider — raw HTML preserved
const rawHtml = `<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>GoClaw v2.18.0 — Embedding Dimensions Multi-Provider</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e1a;
    --surface: #0f1629;
    --surface2: #141d35;
    --surface3: #1a2540;
    --border: #1e2d4a;
    --text: #e2e8f0;
    --text-muted: #64748b;
    --accent: #6366f1;
    --accent2: #818cf8;
    --accent-bg: rgba(99,102,241,0.1);
    --green: #10b981;
    --orange: #f59e0b;
    --red: #ef4444;
    --cyan: #06b6d4;
    --purple: #a855f7;
    --sans: 'Plus Jakarta Sans', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(0,0,0,0.4);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }

  .float-home {
    position: fixed; bottom: 24px; left: 24px; z-index: 100;
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(15,22,41,0.9); backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); text-decoration: none;
    transition: all 0.25s; box-shadow: var(--shadow);
  }
  .float-home:hover { background: var(--accent); color: #fff; border-color: transparent; transform: translateY(-2px); }
  .float-home svg { width: 18px; height: 18px; }

  .lang-bar { position: fixed; top: 16px; right: 16px; z-index: 100; display: flex; gap: 4px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 4px; box-shadow: var(--shadow); }
  .lang-btn { font-family: var(--mono); font-size: 11px; font-weight: 600; padding: 4px 9px; border-radius: 7px; border: none; background: transparent; color: var(--text-muted); cursor: pointer; transition: all .2s; }
  .lang-btn.active { background: var(--accent); color: #fff; }
  .lang-btn:hover:not(.active) { background: var(--surface2); color: var(--text); }

  /* HERO */
  .hero { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 80px 24px 60px; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 50% at 50% 20%, rgba(99,102,241,0.12) 0%, transparent 65%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; inset: 0; background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(99,102,241,0.03) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(99,102,241,0.03) 40px); pointer-events: none; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border: 1px solid var(--border); border-radius: 100px; font-family: var(--mono); font-size: 12px; color: var(--text-muted); margin-bottom: 28px; background: var(--surface); box-shadow: var(--shadow); animation: fadeUp .8s ease both; position: relative; z-index: 1; }
  .hero-badge .dot { width: 6px; height: 6px; background: var(--accent2); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
  .hero h1 { font-size: clamp(32px, 6vw, 62px); font-weight: 800; line-height: 1.1; max-width: 740px; animation: fadeUp 1s ease .1s both; position: relative; z-index: 1; }
  .hero h1 .hl { background: linear-gradient(135deg, var(--accent2) 0%, var(--cyan) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-sub { max-width: 560px; font-size: 17px; color: var(--text-muted); margin-top: 20px; animation: fadeUp 1s ease .2s both; position: relative; z-index: 1; }
  .hero-meta { margin-top: 28px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center; animation: fadeUp 1s ease .3s both; position: relative; z-index: 1; }
  .hero-tag { font-family: var(--mono); font-size: 11px; padding: 4px 10px; border-radius: 6px; background: var(--accent-bg); color: var(--accent2); border: 1px solid rgba(99,102,241,0.25); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)} }

  .content { max-width: 760px; margin: 0 auto; padding: 0 24px; }
  section { padding: 64px 0; }
  .section-label { font-family: var(--mono); font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--accent2); margin-bottom: 10px; display: block; }
  h2 { font-size: clamp(26px, 4vw, 38px); font-weight: 800; line-height: 1.15; margin-bottom: 18px; }
  h2 .hl { background: linear-gradient(135deg, var(--accent2), var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--accent2); }
  p { font-size: 16px; color: var(--text-muted); margin-bottom: 14px; }
  strong { color: var(--text); }
  code { font-family: var(--mono); font-size: 13px; background: var(--accent-bg); color: var(--accent2); padding: 2px 7px; border-radius: 4px; }
  .divider { width: 40px; height: 2px; background: var(--border); margin: 0 auto; }

  /* PROVIDER COMPARISON TABLE */
  .prov-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 24px 0; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
  .prov-table th { background: var(--surface2); padding: 12px 16px; text-align: left; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid var(--border); }
  .prov-table td { padding: 14px 16px; font-size: 14px; border-bottom: 1px solid var(--border); background: var(--surface); color: var(--text-muted); vertical-align: middle; }
  .prov-table tr:last-child td { border-bottom: none; }
  .prov-table td:first-child { font-family: var(--mono); font-weight: 600; color: var(--text); }
  .dim-bar-wrap { display: flex; align-items: center; gap: 8px; }
  .dim-bar { height: 6px; border-radius: 3px; background: var(--surface3); flex: 1; overflow: hidden; }
  .dim-fill { height: 100%; border-radius: 3px; }
  .dim-fill.openai { background: linear-gradient(90deg, #10b981, #059669); }
  .dim-fill.gemini { background: linear-gradient(90deg, #f59e0b, #d97706); }
  .dim-fill.cohere { background: linear-gradient(90deg, #a855f7, #7c3aed); }
  .dim-fill.dashscope { background: linear-gradient(90deg, #06b6d4, #0284c7); }
  .dim-fill.mistral { background: linear-gradient(90deg, #6366f1, #4f46e5); }
  .dim-num { font-family: var(--mono); font-size: 12px; color: var(--text); min-width: 40px; }
  .trunc-badge { font-family: var(--mono); font-size: 10px; padding: 2px 7px; border-radius: 5px; margin-left: 4px; }
  .trunc-badge.native { background: rgba(16,185,129,0.15); color: #34d399; }
  .trunc-badge.truncated { background: rgba(245,158,11,0.15); color: #fbbf24; }

  /* FLOW DIAGRAM */
  .flow-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 24px; margin: 28px 0; }
  .flow-title { font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--text-muted); text-align: center; margin-bottom: 24px; }
  .flow-steps { display: flex; align-items: center; gap: 0; overflow-x: auto; padding-bottom: 4px; }
  .flow-step { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 14px 14px; flex-shrink: 0; min-width: 120px; text-align: center; }
  .flow-step.highlight { border-color: rgba(99,102,241,0.4); background: rgba(99,102,241,0.08); }
  .flow-step-icon { width: 30px; height: 30px; border-radius: 8px; background: var(--accent-bg); display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; }
  .flow-step-icon svg { width: 14px; height: 14px; color: var(--accent2); }
  .flow-step-label { font-size: 12px; font-weight: 600; color: var(--text); }
  .flow-step-sub { font-size: 11px; color: var(--text-muted); margin-top: 3px; font-family: var(--mono); }
  .flow-arrow { color: var(--text-muted); padding: 0 8px; flex-shrink: 0; font-size: 18px; }

  /* CODE */
  .code-block { background: #050810; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin: 20px 0; }
  .code-header { background: var(--surface2); padding: 10px 16px; font-family: var(--mono); font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; }
  .code-header .file-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .code-body { padding: 16px; overflow-x: auto; }
  .code-body pre { font-family: var(--mono); font-size: 13px; line-height: 1.7; color: rgba(255,255,255,0.6); }
  .ck { color: #93c5fd; }
  .cv { color: #86efac; }
  .cc { color: rgba(255,255,255,0.28); font-style: italic; }
  .cm { color: #c084fc; }
  .cs { color: #fcd34d; }

  /* BEFORE/AFTER */
  .ba-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 24px 0; }
  .ba-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
  .ba-card.after { border-color: rgba(99,102,241,0.3); background: rgba(99,102,241,0.05); }
  .ba-label { font-family: var(--mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .ba-label.before-l { color: var(--red); }
  .ba-label.after-l { color: var(--green); }
  .ba-item { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; font-size: 14px; color: var(--text-muted); }
  .ba-item svg { width: 14px; height: 14px; flex-shrink: 0; margin-top: 3px; }

  /* VECTOR VIZ */
  .vector-viz { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin: 24px 0; overflow-x: auto; }
  .vec-label { font-family: var(--mono); font-size: 11px; color: var(--text-muted); margin-bottom: 12px; }
  .vec-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .vec-name { font-family: var(--mono); font-size: 12px; color: var(--text); min-width: 100px; flex-shrink: 0; }
  .vec-blocks { display: flex; gap: 2px; flex: 1; min-width: 0; }
  .vec-block { height: 18px; border-radius: 3px; flex-shrink: 0; }
  .vec-info { font-family: var(--mono); font-size: 11px; color: var(--text-muted); min-width: 80px; text-align: right; flex-shrink: 0; }
  .vec-cutline { position: relative; }
  .vec-cutline::after { content: '1536'; position: absolute; top: -18px; right: 0; font-family: var(--mono); font-size: 10px; color: var(--accent2); }

  .footer { background: var(--surface); border-top: 1px solid var(--border); padding: 48px 24px; text-align: center; }
  .footer p { font-size: 14px; color: var(--text-muted); margin-bottom: 8px; }
  .footer a { color: var(--accent2); text-decoration: none; }

  @media (max-width: 640px) {
    .float-home { bottom: 16px; left: 16px; width: 40px; height: 40px; border-radius: 10px; }
    .lang-bar { top: 10px; right: 10px; padding: 3px; }
    .hero { min-height: auto; padding: 64px 16px 48px; }
    .hero h1 { font-size: clamp(24px, 8vw, 34px); }
    .hero-sub { font-size: 15px; }
    section { padding: 48px 0; }
    .content { padding: 0 16px; }
    h2 { font-size: clamp(20px, 6vw, 28px); }
    .ba-grid { grid-template-columns: 1fr; }
    .flow-steps { flex-direction: column; align-items: stretch; }
    .flow-arrow { transform: rotate(90deg); text-align: center; }
    .prov-table { font-size: 12px; }
    .prov-table th, .prov-table td { padding: 10px 10px; }
    .dim-bar-wrap { flex-wrap: wrap; gap: 4px; }
  }
</style>
</head>
<body>

<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('vi')">VI</button>
  <button class="lang-btn" onclick="setLang('en')">EN</button>
  <button class="lang-btn" onclick="setLang('zh')">CN</button>
  <button class="lang-btn" onclick="setLang('ja')">JP</button>
</div>

<a href="/" class="float-home" title="Home">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
</a>

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">
    <span class="dot"></span>
    <span data-i18n="badge">GoClaw v2.18.0 — March 25, 2026</span>
  </div>
  <h1 data-i18n="hero-title">Embedding Dimensions Across <span class="hl">Multi-Provider Models</span></h1>
  <p class="hero-sub" data-i18n="hero-sub">Data-driven dimension configuration with per-provider truncation — OpenAI, Gemini, Cohere, DashScope all normalized to pgvector-compatible 1536 dimensions.</p>
  <div class="hero-meta">
    <span class="hero-tag">Vector DB</span>
    <span class="hero-tag">Embeddings</span>
    <span class="hero-tag">pgvector</span>
    <span class="hero-tag">Multi-Provider</span>
  </div>
</div>

<div class="content">

  <!-- PROBLEM -->
  <section>
    <span class="section-label" data-i18n="s1-label">01 — The Problem</span>
    <h2 data-i18n="s1-title">Every provider outputs <span class="hl">different dimensions</span></h2>
    <p data-i18n="s1-p1">pgvector requires a fixed column width. GoClaw's <code>embeddings</code> table is defined as <code>vector(1536)</code>. If a provider returns 3072 dimensions (like Gemini's native output), the insert fails.</p>
    <p data-i18n="s1-p2">Before v2.18.0, Gemini truncation was hardcoded. Adding any new provider required a code change. v2.18.0 makes dimension handling fully <strong>data-driven and per-provider configurable</strong>.</p>

    <!-- Vector viz -->
    <div class="vector-viz">
      <div class="vec-label" data-i18n="vec-label">Embedding dimensions by provider — all normalized to 1536 for pgvector storage</div>
      <div class="vec-row">
        <div class="vec-name">OpenAI</div>
        <div class="vec-blocks">
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#10b981,#059669);opacity:.8;"></div>
        </div>
        <div class="vec-info">1536 <span class="trunc-badge native" data-i18n="native">native</span></div>
      </div>
      <div class="vec-row">
        <div class="vec-name">Gemini</div>
        <div class="vec-blocks">
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#f59e0b,#d97706);opacity:.5;"></div>
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#f59e0b,#d97706);opacity:.15;border:1px dashed rgba(245,158,11,0.4);"></div>
        </div>
        <div class="vec-info">3072 → 1536 <span class="trunc-badge truncated" data-i18n="truncated">truncated</span></div>
      </div>
      <div class="vec-row">
        <div class="vec-name">Cohere</div>
        <div class="vec-blocks">
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#a855f7,#7c3aed);opacity:.8;"></div>
        </div>
        <div class="vec-info">1536 <span class="trunc-badge native" data-i18n="native">native</span></div>
      </div>
      <div class="vec-row">
        <div class="vec-name">DashScope</div>
        <div class="vec-blocks">
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#06b6d4,#0284c7);opacity:.8;"></div>
        </div>
        <div class="vec-info">1536 <span class="trunc-badge truncated" data-i18n="via-dim">via dims</span></div>
      </div>
      <div class="vec-row">
        <div class="vec-name">Mistral</div>
        <div class="vec-blocks">
          <div class="vec-block" style="width:100%;background:linear-gradient(90deg,#6366f1,#4f46e5);opacity:.8;"></div>
        </div>
        <div class="vec-info">1536 <span class="trunc-badge native" data-i18n="native">native</span></div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROVIDER TABLE -->
  <section>
    <span class="section-label" data-i18n="s2-label">02 — Provider Comparison</span>
    <h2 data-i18n="s2-title">Verified <span class="hl">1536d</span> models per provider</h2>
    <p data-i18n="s2-p1">The system settings modal curates embedding models verified to produce or be truncated to 1536 dimensions. Each provider type has its own model list.</p>

    <table class="prov-table">
      <thead>
        <tr>
          <th data-i18n="th-provider">Provider</th>
          <th data-i18n="th-model">Model</th>
          <th data-i18n="th-native">Native dims</th>
          <th data-i18n="th-method">Method</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>OpenAI</td>
          <td><code>text-embedding-3-small</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill openai" style="width:50%"></div></div><span class="dim-num">1536</span></div></td>
          <td><span class="trunc-badge native" data-i18n="native">native</span></td>
        </tr>
        <tr>
          <td>OpenAI</td>
          <td><code>text-embedding-3-large</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill openai" style="width:100%"></div></div><span class="dim-num">3072</span></div></td>
          <td><span class="trunc-badge truncated" data-i18n="via-param">dimensions param</span></td>
        </tr>
        <tr>
          <td>Gemini</td>
          <td><code>gemini-embedding-001</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill gemini" style="width:100%"></div></div><span class="dim-num">3072</span></div></td>
          <td><span class="trunc-badge truncated" data-i18n="via-param">dimensions param</span></td>
        </tr>
        <tr>
          <td>Cohere</td>
          <td><code>embed-v4</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill cohere" style="width:50%"></div></div><span class="dim-num">1536</span></div></td>
          <td><span class="trunc-badge native" data-i18n="native">native</span></td>
        </tr>
        <tr>
          <td>DashScope</td>
          <td><code>text-embedding-v3</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill dashscope" style="width:50%"></div></div><span class="dim-num">1536</span></div></td>
          <td><span class="trunc-badge truncated" data-i18n="via-param">dimensions param</span></td>
        </tr>
        <tr>
          <td>Mistral</td>
          <td><code>codestral-embed</code></td>
          <td><div class="dim-bar-wrap"><div class="dim-bar"><div class="dim-fill mistral" style="width:50%"></div></div><span class="dim-num">1536</span></div></td>
          <td><span class="trunc-badge native" data-i18n="native">native</span></td>
        </tr>
      </tbody>
    </table>
  </section>

  <div class="divider"></div>

  <!-- FLOW -->
  <section>
    <span class="section-label" data-i18n="s3-label">03 — Config Flow</span>
    <h2 data-i18n="s3-title">From provider config to <span class="hl">pgvector insert</span></h2>
    <p data-i18n="s3-p1">When a provider is configured with a <code>dimensions</code> value, the embedding client passes it as a request parameter. The provider truncates at the source — no post-processing needed, preserving semantic fidelity.</p>

    <div class="flow-box">
      <div class="flow-title" data-i18n="flow-title">Embedding Config → Verification → Vector Storage</div>
      <div class="flow-steps">
        <div class="flow-step highlight">
          <div class="flow-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
          </div>
          <div class="flow-step-label" data-i18n="fl-s1">Provider Config</div>
          <div class="flow-step-sub">dimensions: 1536</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <div class="flow-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <div class="flow-step-label" data-i18n="fl-s2">Verify Endpoint</div>
          <div class="flow-step-sub">POST /v1/provider/verify</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step highlight">
          <div class="flow-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <div class="flow-step-label" data-i18n="fl-s3">Dim Check</div>
          <div class="flow-step-sub" data-i18n="fl-s3s">valid: true, dim: 1536</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <div class="flow-step-icon">
