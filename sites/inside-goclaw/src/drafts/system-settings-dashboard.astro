---
// Draft: system-settings-dashboard — raw HTML preserved
const rawHtml = `<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>GoClaw v2.9.0 — System Settings Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0c0c10;
    --surface: #131318;
    --surface2: #18181f;
    --surface3: #1e1e28;
    --border: #252530;
    --border2: #2a2a38;
    --text: #e8e8f0;
    --text-muted: #6b6b80;
    --accent: #7c3aed;
    --accent2: #a78bfa;
    --accent-bg: rgba(124,58,237,0.1);
    --green: #10b981;
    --orange: #f59e0b;
    --red: #ef4444;
    --cyan: #22d3ee;
    --sans: 'Plus Jakarta Sans', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(0,0,0,0.5);
    --glow: 0 0 40px rgba(124,58,237,0.12);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }

  .float-home {
    position: fixed; bottom: 24px; left: 24px; z-index: 100;
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(19,19,24,0.9); backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); text-decoration: none;
    transition: all 0.25s; box-shadow: var(--shadow);
  }
  .float-home:hover { background: var(--accent); color: #fff; border-color: transparent; transform: translateY(-2px); }
  .float-home svg { width: 18px; height: 18px; }

  .lang-bar { position: fixed; top: 16px; right: 16px; z-index: 100; display: flex; gap: 4px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 4px; box-shadow: var(--shadow); }
  .lang-btn { font-family: var(--mono); font-size: 11px; font-weight: 600; padding: 4px 9px; border-radius: 7px; border: none; background: transparent; color: var(--text-muted); cursor: pointer; transition: all .2s; }
  .lang-btn.active { background: var(--accent); color: #fff; }
  .lang-btn:hover:not(.active) { background: var(--surface2); color: var(--text); }

  /* HERO */
  .hero { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 80px 24px 60px; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 45% at 50% 20%, rgba(124,58,237,0.13) 0%, transparent 65%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; inset: 0; background-image: repeating-linear-gradient(0deg, transparent, transparent 47px, rgba(124,58,237,0.025) 48px), repeating-linear-gradient(90deg, transparent, transparent 47px, rgba(124,58,237,0.025) 48px); pointer-events: none; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border: 1px solid var(--border); border-radius: 100px; font-family: var(--mono); font-size: 12px; color: var(--text-muted); margin-bottom: 28px; background: var(--surface); box-shadow: var(--shadow); animation: fadeUp .8s ease both; position: relative; z-index: 1; }
  .hero-badge .dot { width: 6px; height: 6px; background: var(--accent2); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
  .hero h1 { font-size: clamp(30px, 6vw, 60px); font-weight: 800; line-height: 1.1; max-width: 720px; animation: fadeUp 1s ease .1s both; position: relative; z-index: 1; }
  .hero h1 .hl { background: linear-gradient(135deg, var(--accent2) 0%, var(--cyan) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-sub { max-width: 560px; font-size: 17px; color: var(--text-muted); margin-top: 20px; animation: fadeUp 1s ease .2s both; position: relative; z-index: 1; }
  .hero-meta { margin-top: 28px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center; animation: fadeUp 1s ease .3s both; position: relative; z-index: 1; }
  .hero-tag { font-family: var(--mono); font-size: 11px; padding: 4px 10px; border-radius: 6px; background: var(--accent-bg); color: var(--accent2); border: 1px solid rgba(124,58,237,0.25); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)} }

  .content { max-width: 760px; margin: 0 auto; padding: 0 24px; }
  section { padding: 64px 0; }
  .section-label { font-family: var(--mono); font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--accent2); margin-bottom: 10px; display: block; }
  h2 { font-size: clamp(24px, 4vw, 36px); font-weight: 800; line-height: 1.15; margin-bottom: 18px; }
  h2 .hl { background: linear-gradient(135deg, var(--accent2), var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  h3 { font-size: 17px; font-weight: 700; margin: 22px 0 9px; color: var(--accent2); }
  p { font-size: 16px; color: var(--text-muted); margin-bottom: 14px; }
  strong { color: var(--text); }
  code { font-family: var(--mono); font-size: 13px; background: var(--accent-bg); color: var(--accent2); padding: 2px 7px; border-radius: 4px; }
  .divider { width: 40px; height: 2px; background: var(--border); margin: 0 auto; }

  /* SETTINGS MODAL MOCKUP */
  .modal-mock { background: var(--surface); border: 1px solid var(--border2); border-radius: var(--radius); overflow: hidden; margin: 28px 0; box-shadow: var(--shadow), var(--glow); }
  .mm-titlebar { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; background: var(--surface2); border-bottom: 1px solid var(--border); }
  .mm-title-left { display: flex; align-items: center; gap: 8px; }
  .mm-title-icon { width: 28px; height: 28px; border-radius: 7px; background: var(--accent-bg); display: flex; align-items: center; justify-content: center; }
  .mm-title-icon svg { width: 14px; height: 14px; color: var(--accent2); }
  .mm-title-text { font-size: 14px; font-weight: 700; color: var(--text); }
  .mm-close { width: 24px; height: 24px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text-muted); display: flex; align-items: center; justify-content: center; cursor: pointer; }
  .mm-close svg { width: 12px; height: 12px; }
  .mm-body { padding: 16px 18px; display: flex; flex-direction: column; gap: 12px; }
  /* Setting Section Card */
  .ss-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .ss-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 14px; border-bottom: 1px solid var(--border); }
  .ss-card-icon { width: 22px; height: 22px; border-radius: 5px; background: var(--accent-bg); display: flex; align-items: center; justify-content: center; }
  .ss-card-icon svg { width: 11px; height: 11px; color: var(--accent2); }
  .ss-card-title { font-size: 12px; font-weight: 700; color: var(--text); }
  .ss-card-body { padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }
  .ss-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .ss-label { font-size: 12px; color: var(--text-muted); flex: 1; }
  .ss-input { font-family: var(--mono); font-size: 11px; background: var(--surface3); border: 1px solid var(--border); border-radius: 6px; padding: 4px 8px; color: var(--text); width: 120px; }
  .ss-toggle { width: 36px; height: 20px; border-radius: 10px; position: relative; flex-shrink: 0; cursor: pointer; }
  .ss-toggle.on { background: var(--accent); }
  .ss-toggle.off { background: var(--surface3); border: 1px solid var(--border); }
  .ss-toggle-knob { width: 14px; height: 14px; border-radius: 50%; background: #fff; position: absolute; top: 3px; transition: left .2s; }
  .ss-toggle.on .ss-toggle-knob { left: 19px; }
  .ss-toggle.off .ss-toggle-knob { left: 3px; }
  .mm-footer { display: flex; justify-content: flex-end; padding: 0 18px 14px; }
  .mm-save-btn { font-family: var(--sans); font-size: 12px; font-weight: 600; padding: 7px 16px; border-radius: 8px; border: none; background: var(--accent); color: #fff; cursor: pointer; display: flex; align-items: center; gap: 6px; }
  .mm-save-btn svg { width: 13px; height: 13px; }

  /* CONFIG FLOW DIAGRAM */
  .cfg-flow { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 20px; margin: 28px 0; }
  .cfg-flow-title { font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--text-muted); text-align: center; margin-bottom: 24px; }
  .cfg-steps { display: flex; align-items: center; gap: 0; overflow-x: auto; padding-bottom: 4px; }
  .cfg-step { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 14px 12px; flex-shrink: 0; min-width: 120px; text-align: center; }
  .cfg-step.hi { background: rgba(124,58,237,0.08); border-color: rgba(124,58,237,0.35); }
  .cfg-step-icon { width: 28px; height: 28px; border-radius: 7px; background: var(--accent-bg); display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; }
  .cfg-step-icon svg { width: 13px; height: 13px; color: var(--accent2); }
  .cfg-step-label { font-size: 12px; font-weight: 600; color: var(--text); }
  .cfg-step-sub { font-size: 10px; color: var(--text-muted); margin-top: 3px; font-family: var(--mono); }
  .cfg-arrow { color: var(--text-muted); padding: 0 6px; flex-shrink: 0; font-size: 18px; }

  /* SECTIONS TABLE */
  .sections-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 24px 0; border-radius: 12px; overflow: hidden; border: 1px solid var(--border); }
  .sections-table th { background: var(--surface2); padding: 11px 16px; text-align: left; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid var(--border); }
  .sections-table td { padding: 13px 16px; font-size: 14px; border-bottom: 1px solid var(--border); background: var(--surface); color: var(--text-muted); vertical-align: top; }
  .sections-table tr:last-child td { border-bottom: none; }
  .sections-table td:first-child { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--accent2); white-space: nowrap; }
  .key-list { display: flex; flex-direction: column; gap: 3px; }
  .key-tag { font-family: var(--mono); font-size: 11px; background: var(--accent-bg); color: var(--accent2); padding: 2px 7px; border-radius: 4px; display: inline-block; margin-right: 4px; margin-bottom: 3px; }

  /* CODE */
  .code-block { background: #08080f; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin: 20px 0; }
  .code-header { background: var(--surface2); padding: 10px 16px; font-family: var(--mono); font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border); }
  .code-header .file-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .code-body { padding: 16px; overflow-x: auto; }
  .code-body pre { font-family: var(--mono); font-size: 13px; line-height: 1.7; color: rgba(255,255,255,0.6); }
  .ck { color: #93c5fd; }
  .cv { color: #c4b5fd; }
  .cc { color: rgba(255,255,255,0.28); font-style: italic; }
  .cm { color: #86efac; }
  .cs { color: #fcd34d; }

  .footer { background: var(--surface); border-top: 1px solid var(--border); padding: 48px 24px; text-align: center; }
  .footer p { font-size: 14px; color: var(--text-muted); margin-bottom: 8px; }
  .footer a { color: var(--accent2); text-decoration: none; }

  @media (max-width: 640px) {
    .float-home { bottom: 16px; left: 16px; width: 40px; height: 40px; border-radius: 10px; }
    .lang-bar { top: 10px; right: 10px; padding: 3px; }
    .hero { min-height: auto; padding: 64px 16px 48px; }
    .hero h1 { font-size: clamp(22px, 8vw, 32px); }
    .hero-sub { font-size: 15px; }
    section { padding: 48px 0; }
    .content { padding: 0 16px; }
    h2 { font-size: clamp(20px, 6vw, 28px); }
    .cfg-steps { flex-direction: column; align-items: stretch; }
    .cfg-arrow { transform: rotate(90deg); text-align: center; }
    .sections-table { font-size: 12px; }
    .sections-table th, .sections-table td { padding: 10px 10px; }
    .ss-input { width: 90px; }
  }
</style>
</head>
<body>

<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('vi')">VI</button>
  <button class="lang-btn" onclick="setLang('en')">EN</button>
  <button class="lang-btn" onclick="setLang('zh')">CN</button>
  <button class="lang-btn" onclick="setLang('ja')">JP</button>
</div>

<a href="/" class="float-home" title="Home">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
</a>

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">
    <span class="dot"></span>
    <span data-i18n="badge">GoClaw v2.9.0 — March 17, 2026</span>
  </div>
  <h1 data-i18n="hero-title"><span class="hl">System Settings</span> Dashboard for Multi-Tenant Deployments</h1>
  <p class="hero-sub" data-i18n="hero-sub">A gear icon in the navbar opens a modal to configure embedding providers, toggle gateway behaviors, and tune compaction — no config.json edits, no restarts.</p>
  <div class="hero-meta">
    <span class="hero-tag">Admin</span>
    <span class="hero-tag">Multi-Tenant</span>
    <span class="hero-tag">Configuration</span>
    <span class="hero-tag">Operations</span>
  </div>
</div>

<div class="content">

  <!-- MODAL WALKTHROUGH -->
  <section>
    <span class="section-label" data-i18n="s1-label">01 — Settings Modal</span>
    <h2 data-i18n="s1-title">Three sections, <span class="hl">one place</span></h2>
    <p data-i18n="s1-p1">The System Settings modal is opened from the gear icon in the top navigation bar. It exposes three configuration sections: <strong>Embedding</strong>, <strong>UX Behavior</strong>, and <strong>Pending Compaction</strong>. All settings are per-tenant — no cross-tenant leakage.</p>

    <div class="modal-mock">
      <div class="mm-titlebar">
        <div class="mm-title-left">
          <div class="mm-title-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
          </div>
          <span class="mm-title-text" data-i18n="mm-title">System Settings</span>
        </div>
        <div class="mm-close">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </div>
      </div>
      <div class="mm-body">
        <!-- Embedding section -->
        <div class="ss-card">
          <div class="ss-card-header">
            <div class="ss-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12v.01"/><path d="M7 12v.01"/><path d="M17 12v.01"/></svg>
            </div>
            <span class="ss-card-title" data-i18n="card1-title">Embedding</span>
          </div>
          <div class="ss-card-body">
            <div class="ss-row">
              <span class="ss-label" data-i18n="emb-provider">Provider</span>
              <input class="ss-input" value="openai_compat" readonly>
            </div>
            <div class="ss-row">
              <span class="ss-label" data-i18n="emb-model">Model</span>
              <input class="ss-input" value="text-embedding-3-small" readonly style="width:160px">
            </div>
            <div class="ss-row">
              <span class="ss-label" data-i18n="emb-chunk">Max Chunk Len</span>
              <input class="ss-input" value="512" readonly>
            </div>
          </div>
        </div>
        <!-- UX Behavior -->
        <div class="ss-card">
          <div class="ss-card-header">
            <div class="ss-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <span class="ss-card-title" data-i18n="card2-title">UX Behavior</span>
          </div>
          <div class="ss-card-body">
            <div class="ss-row">
              <span class="ss-label" data-i18n="ux-toolstatus">Tool Status</span>
              <div class="ss-toggle on"><div class="ss-toggle-knob"></div></div>
            </div>
            <div class="ss-row">
              <span class="ss-label" data-i18n="ux-blockreply">Block Reply</span>
              <div class="ss-toggle off"><div class="ss-toggle-knob"></div></div>
            </div>
            <div class="ss-row">
              <span class="ss-label" data-i18n="ux-intent">Intent Classify</span>
              <div class="ss-toggle on"><div class="ss-toggle-knob"></div></div>
            </div>
          </div>
        </div>
        <!-- Compaction -->
        <div class="ss-card">
          <div class="ss-card-header">
            <div class="ss-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <span class="ss-card-title" data-i18n="card3-title">Pending Compaction</span>
          </div>
          <div class="ss-card-body">
            <div class="ss-row">
              <span class="ss-label" data-i18n="comp-thresh">Threshold</span>
              <input class="ss-input" value="20" readonly>
            </div>
            <div class="ss-row">
              <span class="ss-label" data-i18n="comp-keep">Keep Recent</span>
              <input class="ss-input" value="5" readonly>
            </div>
          </div>
        </div>
      </div>
      <div class="mm-footer">
        <button class="mm-save-btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <span data-i18n="mm-save">Save Changes</span>
        </button>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONFIG FLOW -->
  <section>
    <span class="section-label" data-i18n="s2-label">02 — Config Flow</span>
    <h2 data-i18n="s2-title">DB → memory → <span class="hl">runtime</span></h2>
    <p data-i18n="s2-p1"><code>ApplySystemConfigs</code> overlays <code>system_configs</code> DB values onto the in-memory config at two points: <strong>startup seed</strong> and <strong>after save</strong>. The DB always wins over <code>config.json</code> — operators manage config through the UI, developers set defaults in the file.</p>

    <div class="cfg-flow">
      <div class="cfg-flow-title" data-i18n="flow-title">Config Resolution — DB overrides config.json</div>
      <div class="cfg-steps">
        <div class="cfg-step">
          <div class="cfg-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="cfg-step-label">config.json</div>
          <div class="cfg-step-sub" data-i18n="fl-s1s">dev defaults</div>
        </div>
        <div class="cfg-arrow">+</div>
        <div class="cfg-step hi">
          <div class="cfg-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <div class="cfg-step-label">system_configs</div>
          <div class="cfg-step-sub" data-i18n="fl-s2s">DB per-tenant</div>
        </div>
        <div class="cfg-arrow">→</div>
        <div class="cfg-step hi">
          <div class="cfg-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8"/><path d="M12 7v14"/></svg>
          </div>
          <div class="cfg-step-label" data-i18n="fl-s3">Memory Overlay</div>
          <div class="cfg-step-sub">ApplySystemConfigs</div>
        </div>
        <div class="cfg-arrow">→</div>
        <div class="cfg-step">
          <div class="cfg-step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="cfg-step-label" data-i18n="fl-s4">Runtime</div>
          <div class="cfg-step-sub" data-i18n="fl-s4s">live config</div>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="code-header">
        <div class="file-dot"></div>
        internal/config/config_system.go
      </div>
      <div class="code-body">
        <pre><span class="cc">// ApplySystemConfigs overlays DB values onto in-memory config.</span>
<span class="cc">// Called after startup seed and after config.apply/patch.</span>
<span class="cc">// Non-empty DB values override config.json values.</span>
<span class="ck">func</span> (c *<span class="cv">Config</span>) <span class="cm">ApplySystemConfigs</span>(configs map[<span class="cs">string</span>]<span class="cs">string</span>) {
    <span class="cc">// Embedding</span>
    str(<span class="cs">"embedding.provider"</span>, &amp;c.Agents.Defaults.Memory.EmbeddingProvider)
    str(<span class="cs">"embedding.model"</span>,    &amp;c.Agents.Defaults.Memory.EmbeddingModel)
    integer(<span class="cs">"embedding.max_chunk_len"</span>, &amp;c.Agents.Defaults.Memory.MaxChunkLen)

    <span class="cc">// Gateway behavior</span>
    boolean(<span class="cs">"gateway.tool_status"</span>,  &amp;c.Gateway.ToolStatus)
    boolean(<span class="cs">"gateway.block_reply"</span>,  &amp;c.Gateway.BlockReply)

    <span class="cc">// Pending compaction</span>
    integer(<span class="cs">"compaction.threshold"</span>,   &amp;pc.Threshold)
    integer(<span class="cs">"compaction.keep_recent"</span>, &amp;pc.KeepRecent)
}</pre>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONFIG KEYS TABLE -->
  <section>
    <span class="section-label" data-i18n="s3-label">03 — Config Keys</span>
    <h2 data-i18n="s3-title">What you can <span class="hl">configure</span></h2>
    <p data-i18n="s3-p1">All keys stored in <code>system_configs</code> as <code>key/value TEXT</code> pairs per tenant. Integer and boolean coercion handled by <code>ApplySystemConfigs</code>.</p>

